int consultaUsuario()
{
	setlocale(LC_ALL, "Portuguese"); //Definindo a linguagem

	char cpf[40];
	char conteudo[200];

	printf("Digite o CPF a ser consultado: ");
	scanf("%s", cpf);

	FILE *file;
	file = fopen(cpf,"r");

	if(file == NULL)
	{
		printf("Não foi possivel abrir o arquivo, não localizado!.\n");
		system("pause");
		return 0;
	}

	while(fgets(conteudo, 200, file) != NULL)
	{
		printf("\nEssas são informações do usuário: ");
		printf("%s", conteudo);
		printf("\n\n");
	}
	
	system("pause");
}

int deletarUsuario()
{
	char cpf[40];

	printf("Digite o CPF do usuário a ser deletado: ");
	scanf("%s", cpf);

	FILE *file = fopen(cpf,"r");

	if(file == NULL)
	{
		printf("Usuário não se encontra no sistema!.\n");
		system("pause");
		return 0;
	}

	fclose(file);
    
	char confirmacao;
	printf("Tem certeza que deseja deletar? (s/n): ");
	scanf(" %c", &confirmacao);

	if(confirmacao == 's' || confirmacao == 'S')
	{
		remove(cpf);
		printf("Usuário deletado com sucesso!\n");
	}
	else 
	{
		printf("operação cancelada\n");
	}
    
	system("pause");
	return 0;
}


